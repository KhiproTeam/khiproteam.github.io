---
import { bn, en } from '../i18n/messages';

interface Props { lang: 'bn' | 'en'; }
const { lang } = Astro.props;
const t = lang === 'en' ? en : bn;
const f = t.footer;

const year = new Date().getFullYear();
---
<footer class="bg-footer-bg py-6 px-6 text-center transition-colors duration-300">
  <p class="text-[13px] text-footer-text">
    &copy; {year} KhiproTeam &middot; {f.tagline}
  </p>
</footer>
