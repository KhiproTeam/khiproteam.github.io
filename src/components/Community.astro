---
import Icon from './Icon.astro';
import { bn, en } from '../i18n/messages';

interface Props { lang: 'bn' | 'en'; }
const { lang } = Astro.props;
const t = lang === 'en' ? en : bn;
const c = t.community as any;

// Presentation only (Tailwind classes). Content lives in JSON.
const presentation: Record<string, { colorClass: string }> = {
  github: { colorClass: 'bg-surface-2 text-text-1 border border-border' },
  facebook: { colorClass: 'bg-[#1877f215] text-[#1877f2] border border-[#1877f225]' },
  telegram: { colorClass: 'bg-[#0088cc15] text-[#0088cc] border border-[#0088cc25]' },
};
const order = ['github', 'facebook', 'telegram'];
const items = order.map((key) => ({ key, ...presentation[key], ...c.items[key] }));
---

<section id="community" class="py-14 sm:py-16 bg-bg-alt transition-colors duration-300">
  <div class="w-full max-w-[860px] mx-auto px-6">
    <header class="text-center mb-10">
      <h2 class="font-heading text-[clamp(2rem,4vw,2.6rem)] font-extrabold text-text-1 tracking-tight mb-3">{c.heading}</h2>
      <p class="text-[15px] text-text-2 max-w-[500px] mx-auto leading-relaxed">{c.subheading}</p>
    </header>

    <div class="grid grid-cols-1 gap-5 max-w-[400px] mx-auto sm:grid-cols-3 sm:max-w-none">
      {items.map((item) => (
        <a
          href={item.href}
          target="_blank"
          rel="noopener noreferrer"
          class="block bg-surface border border-border rounded-2xl p-8 text-center no-underline transition-colors duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-teal"
        >
          <div class={`w-14 h-14 rounded-[14px] flex items-center justify-center text-[22px] mx-auto mb-5 ${item.colorClass}`}>
            <Icon name={item.icon} />
          </div>
          <h3 class="font-heading text-lg font-bold text-text-1 mb-2 tracking-tight">{item.name}</h3>
          <p class="text-[13.5px] text-text-3 leading-relaxed mb-4">{item.description}</p>
          <div class="inline-flex items-center gap-1.5 text-[13px] font-medium text-teal-mid">
            {item.action}
            <Icon name="arrow-right" class="text-[11px]" />
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
