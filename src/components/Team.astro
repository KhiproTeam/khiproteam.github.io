---
import Icon from './Icon.astro';
import { bn, en } from '../i18n/messages';

interface Props { lang: 'bn' | 'en'; }
const { lang } = Astro.props;
const t = lang === 'en' ? en : bn;
const team = t.team as any;

const members = [
  { key: 'nafee' },
  { key: 'qomarul' },
  { key: 'tareq' },
];
---

<section id="team" class="py-14 sm:py-16 bg-bg transition-colors duration-300">
  <div class="w-full max-w-[900px] mx-auto px-6">
    <header class="text-center mb-10">
      <h2 class="font-heading text-[clamp(2rem,4vw,2.6rem)] font-extrabold text-text-1 tracking-tight mb-3">{team.heading}</h2>
      <p class="text-[15px] text-text-2 max-w-[500px] mx-auto leading-relaxed">{team.subheading}</p>
    </header>

    <div class="grid grid-cols-1 gap-5 max-w-[400px] mx-auto sm:grid-cols-3 sm:max-w-none">
      {members.map((member) => (
        <div class="bg-surface border border-border rounded-2xl p-8 text-center relative overflow-hidden transition-colors duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-teal">
          <img
            src={team.members[member.key].avatar}
            alt={team.members[member.key].name}
            width="72"
            height="72"
            loading="lazy"
            decoding="async"
            class="w-[72px] h-[72px] rounded-full object-cover shrink-0 border-[3px] border-teal-light mx-auto mb-5"
          />
          <h3 class="font-heading text-lg font-bold text-text-1 mb-1 tracking-tight">{team.members[member.key].name}</h3>
          <div class="text-[13px] text-text-3 leading-relaxed mb-5 flex flex-col gap-1.5">
            <span class="flex items-center gap-1.5 bg-surface-2 border border-border rounded-lg px-1.5 py-1">
              <span class="inline-block px-2 py-0.5 rounded bg-tag-bg text-tag-text text-[11px] font-semibold shrink-0">{team.members[member.key].project}:</span>
              {team.members[member.key].role}
            </span>
          </div>
          <div class="flex justify-center gap-2">
            {team.members[member.key].socials.map((link: any) => (
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={link.label}
                class="w-[34px] h-[34px] rounded-[9px] border border-border-mid bg-surface-2 text-text-3 flex items-center justify-center text-[13px] no-underline transition-all duration-200 hover:bg-teal hover:text-white hover:border-teal"
              >
                <Icon name={link.icon} />
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
