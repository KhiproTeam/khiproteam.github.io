---
// Site-wide 404 (Astro emits /404.html; GitHub Pages serves it for any miss).
// Bilingual so one page covers both locales. Default lang = bn.
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';
---

<Layout lang="bn">
  <section class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 overflow-hidden">
    <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">
      <span class="absolute top-[12%] left-[8%] font-bengali text-[90px] text-teal-glyph font-semibold rotate-8">ক্ষ</span>
      <span class="absolute bottom-[14%] right-[10%] font-bengali text-[120px] text-teal-glyph font-semibold -rotate-12">৪</span>
    </div>

    <div class="relative z-10">
      <div class="font-heading font-extrabold text-teal text-[clamp(5rem,18vw,9rem)] leading-none tracking-tight">৪০৪</div>
      <div class="text-text-3 font-heading text-sm tracking-[0.3em] mt-1">404</div>

      <h1 class="font-heading text-[clamp(1.6rem,4vw,2.2rem)] font-extrabold text-text-1 mt-8 mb-2">পাতাটি পাওয়া যায়নি</h1>
      <p class="text-text-2 text-[15px] max-w-[460px] mx-auto leading-relaxed mb-1">আপনি যে পাতাটি খুঁজছেন সেটি এখানে নেই।</p>
      <p class="text-text-3 text-[14px] max-w-[460px] mx-auto leading-relaxed mb-9">Page not found — the page you're looking for doesn't exist.</p>

      <div class="flex gap-3 justify-center flex-wrap">
        <a href="/" class="inline-flex items-center gap-2 px-7 py-3 rounded-full bg-linear-to-br from-teal to-teal-deep text-white text-[15px] font-medium no-underline transition-transform duration-200 hover:translate-y-[-2px]">
          <Icon name="arrow-right" class="text-[13px] rotate-180" />
          নীড়পাতায় ফিরুন
        </a>
        <a href="/en/" class="inline-flex items-center gap-2 px-7 py-3 rounded-full border-[1.5px] border-border-mid bg-surface text-text-2 text-[15px] font-medium no-underline transition-colors duration-200 hover:border-teal hover:text-teal hover:bg-tag-bg">
          <Icon name="language" class="text-[15px]" />
          English site
        </a>
      </div>
    </div>
  </section>
</Layout>
